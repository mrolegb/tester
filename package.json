{
  "name": "tester",
  "version": "1.0.0",
  "description": "Minimal users API (Express + SQLite) with TypeScript and agentic test review",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest --runInBand",
    "test:json": "jest --runInBand --json --outputFile=jest-results.json",
    "agent:test": "ts-node scripts/agentic-test-review.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.3",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
